# Copy this file to .env and fill in real values.
# Never commit the actual .env file — it's already in .gitignore below.

# TMDb — get these from themoviedb.org/settings/api once your account works
# (see "Stuck on TMDb access?" note in the README for workarounds)
TMDB_TOKEN=paste_your_v4_read_access_token_here

# Postgres — from your Supabase project settings (Project Settings -> Database -> Connection string)
DATABASE_URL=postgresql://postgres:@K8p$H%Y7N$dSTk@db.quqqewjmoszsbafneddj.supabase.co:5432/postgres

# Auth — any long random string, used to sign login sessions.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=paste_a_random_long_string_here

# Server
PORT=4000
